PORT=3000
NODE_ENV=development

# PostgreSQL connection string (required)
DATABASE_URL=postgres://USER:PASSWORD@localhost:5432/insightcopilot

# Auto-create tables on boot (dev only)
DB_SYNC=true

# Print SQL statements
LOG_SQL=false

# CORS (comma-separated origins or "*")
CORS_ORIGIN=http://localhost:5173

# SQL safety (query timeout in ms)
SQL_TIMEOUT_MS=5000

# Conversation memory (in-memory, resets on server restart)
CONVERSATION_MAX_TURNS=12
CONVERSATION_TTL_MS=1800000

# Optional: in dev, pre-warm Ollama on boot to reduce first-response latency.
# Set to false/0 to disable.
LLM_PREWARM=true

# LiveKit (required for /api/livekit/token and /api/agent/join)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# LiveKit agent dispatch
INSIGHTCOPILOT_AGENT_NAME=
# Or:
LIVEKIT_AGENT_NAME=

# OpenAI (required for arbitrary /api/query questions)
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5

# Ollama (local LLM alternative for arbitrary /api/query questions)
# To use: set LLM_PROVIDER=ollama, run `ollama serve`, and `ollama pull <model>`.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=
OLLAMA_TIMEOUT_MS=60000
